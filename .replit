modules = ["nodejs-20", "web", "bash"]
[userenv]

[userenv.shared]
AUTH_SECRET = "vibe-super-secret-jwt-key-2024-please-change-in-production-xyz789"
NEXT_PUBLIC_APP_URL = ""
INNGEST_DEV = "1"
INNGEST_BASE_URL = "http://127.0.0.1:8290"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Inngest Dev Server"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node_modules/.bin/next dev -p 5000"
waitForPort = 5000

[[workflows.workflow]]
name = "Inngest Dev Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx --yes inngest-cli@1.17.9 dev -u http://localhost:3000/api/inngest --no-discovery --port 8288"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8288
externalPort = 3001

[[ports]]
localPort = 8289
externalPort = 3002

[[ports]]
localPort = 8290
externalPort = 3000

[[ports]]
localPort = 8291
externalPort = 3003

[[ports]]
localPort = 8292
externalPort = 5173

[[ports]]
localPort = 8293
externalPort = 6000

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
