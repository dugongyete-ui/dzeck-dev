DATABASE_URL=""

# App URL — OPTIONAL untuk Replit (auto-detect), wajib untuk platform lain (Vercel, Railway, dll)
# Di Replit tidak perlu diisi — domain otomatis terdeteksi dari REPLIT_DEV_DOMAIN
NEXT_PUBLIC_APP_URL=""

# Auth Secret — digunakan untuk signing JWT session cookie
# Generate dengan: openssl rand -base64 32
AUTH_SECRET=""

# Pollinations AI — https://gen.pollinations.ai
API_KEY=""

# E2B Code Interpreter — https://e2b.dev
E2B_API_KEY=""

# Inngest — https://inngest.com (untuk background job processing)
# Set INNGEST_DEV=1 untuk development lokal (tidak perlu akun Inngest cloud)
# Jalankan: npx inngest-cli@latest dev -u http://localhost:3000/api/inngest --no-discovery
INNGEST_DEV=1
INNGEST_API_KEY=""
INNGEST_SIGNING_KEY=""
